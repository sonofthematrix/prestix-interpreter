# Ignore dependencies and build artifacts
/node_modules
/packages/*/node_modules
/apps/*/node_modules
smart-contracts/node_modules
packages/reown-appkit-module/node_modules

# Ignore build outputs
/build
/.next
/.out
/dist
/dist/**
packages/*/dist

# Ignore MCP server directory (contains Python venv with symlinks)
/tokenizin-mcp-server

# Ignore generated files and caches
/lib/prisma/**
/lib/hooks/**
/lib/enhancer/**
/lib/zod/**
!/lib/.gitkeep

# Ignore compiled JavaScript files in lib directory (TypeScript source files should be used)
/lib/**/*.js
!/lib/**/*.config.js
!/lib/**/*.min.js
.cache-loader
.docusaurus
.build-cache/
.turbo
.cursor
/test-results/
/playwright-report/
/playwright/.cache/

# Ignore environment and config files
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local
next-env.d.ts
*.tsbuildinfo

# Ignore lock and debug files
package-lock.json
bun.lockb
npm-debug.log*
bun-debug.log*
bun-error.log*
.pnpm-debug.log*
.pnp.js
/.pnp

# Ignore IDE/editor files
.idea
.DS_Store

# Ignore deployment and CI/CD files
.vercel
.vercel.json
.vercelignore

# Ignore test coverage
/coverage

# Ignore deprecated and redundant files
/prisma/prisma/
prisma/schema.vercel.prisma

# Ignore misc
*.pem

# Only keep files required for building and packaging
*/node_modules


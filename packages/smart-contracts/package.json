{
  "name": "tigerpalace-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for RWA Marketplace",
  "main": "index.js",
  "scripts": {
    "prepare": "echo 'Smart contracts prepare skipped - manual compilation required'",
    "postinstall": "echo 'Smart contracts postinstall skipped - manual compilation required'",
    "compile": "hardhat compile",
    "test": "REPORT_GAS=true hardhat test",
    "test:gas-report": "bun run scripts/generate-gas-report.ts",
    "test:unit": "hardhat test test/marketplace-token-custody.spec.ts test/usdc-integration.spec.ts test/rwa-token-factory-404*.spec.ts test/security-audit-fixes.spec.ts",
    "test:integration": "hardhat test test/ecosystem-integration.spec.ts test/ecosystem-performance.spec.ts test/integration/",
    "test:e2e": "hardhat test test/e2e/",
    "test:security": "hardhat test test/security-audit-fixes.spec.ts test/integration/end-to-end-security-fixes.spec.ts",
    "test:marketplace": "hardhat test test/marketplace-token-custody.spec.ts test/usdc-integration.spec.ts test/e2e/tiger-palace-marketplace-comprehensive.spec.ts",
    "test:staking": "hardhat test test/rwa-staking*.spec.ts test/tiger-staking*.spec.ts test/tiger-revenue*.spec.ts test/reward-distributor*.spec.ts test/revenue-distribution*.spec.ts test/advanced-revenue-allocation.spec.ts test/enhanced-revenue-allocation.spec.ts",
    "test:comprehensive": "bun run ts-node scripts/run-comprehensive-tests.ts",
    "test:comprehensive:fast": "bun run ts-node scripts/run-comprehensive-tests.ts fast",
    "test:comprehensive:coverage": "bun run ts-node scripts/run-comprehensive-tests.ts coverage",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:analyze": "bun run ts-node scripts/analyze-test-coverage.ts",
    "test:report": "bun run ts-node scripts/generate-test-report.ts",
    "test:organization": "cat test/TEST_ORGANIZATION.md",
    "deploy": "hardhat run scripts/deploy.js",
    "deploy:sepolia": "hardhat run --network sepolia scripts/deploy-sepolia.ts",
    "deploy:upgradeable": "hardhat run scripts/deploy-upgradeable.ts",
    "deploy:local": "hardhat run scripts/deploy-upgradeable.ts --network localhost",
    "deploy:sepolia-upgradeable": "hardhat run scripts/deploy-upgradeable.ts --network sepolia",
    "add": "bun add",
    "add:dev": "bun add -D",
    "test:deployment": "hardhat run scripts/test-local-deployment.ts --network localhost",
    "verify": "hardhat verify",
    "verify:sepolia": "hardhat verify --network sepolia",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "deploy:staking:local": "hardhat run scripts-staking/deploy-rwa-staking-ecosystem.ts --network localhost",
    "deploy:staking:sepolia": "hardhat run scripts-staking/deploy-rwa-staking-ecosystem.ts --network sepolia",
    "deploy:dividend-staking": "hardhat run scripts/deploy-dividend-staking-integration.ts",
    "deploy:dividend-staking:sepolia": "hardhat run scripts/deploy-dividend-staking-integration.ts --network sepolia",
    "setup:dividend-staking": "hardhat run scripts/setup-dividend-staking.ts",
    "setup:dividend-staking:sepolia": "hardhat run scripts/setup-dividend-staking.ts --network sepolia",
    "report:financial": "hardhat run scripts/marketplace-financial-report.ts",
    "report:financial:advanced": "hardhat run scripts/advanced-marketplace-financial-report.ts",
    "dashboard": "hardhat run scripts/marketplace-dashboard.ts",
    "test:staking:integration": "hardhat test test/rwa-staking-integration.spec.ts",
    "test:staking:performance": "hardhat test test/rwa-staking-performance.spec.ts",
    "test:dividend-staking": "hardhat test test/integration/dividend-staking-integration.spec.ts",
    "fix:tests": "bun run scripts/fix-test-files.ts",
    "generate:staking-abis": "ts-node scripts-staking/generate-rwa-frontend-abis.ts",
    "verify:staking:sepolia": "hardhat verify --network sepolia",
    "deploy:marketplace": "hardhat run scripts-staking/deploy-rwa-marketplace.ts --network sepolia",
    "deploy:marketplace:local": "hardhat run scripts-staking/deploy-rwa-marketplace.ts --network localhost",
    "verify:sepolia:all": "hardhat run scripts/verify-sepolia-contracts.ts --network sepolia",
    "deploy:comprehensive:sepolia": "hardhat run scripts/deploy-comprehensive-sepolia.ts --network sepolia",
    "deploy:registry:sepolia": "hardhat run scripts/deploy-registry-upgradeable.ts --network sepolia",
    "deploy:sequential:sepolia": "hardhat run scripts/deploy-sequential-sepolia.ts --network sepolia",
    "verify:deployment": "hardhat run scripts/verify-deployment.ts --network sepolia",
    "health:check": "hardhat run scripts/health-check.ts --network sepolia",
    "update:fee-recipient": "hardhat run scripts/update-fee-recipient.ts --network sepolia",
    "grant-roles": "bun run scripts/grant-roles.ts",
    "test:erc404-finding": "hardhat run scripts/test-erc404-token-finding.ts --network sepolia",
    "monitor:purchases": "hardhat run scripts/monitor-marketplace-purchases.ts --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",

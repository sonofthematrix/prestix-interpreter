{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",
    "lib": ["es2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": false,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "../../src/**/*",
    "./scripts/**/*",
    "./scripts-staking/**/*",
    "./test/**/*",
    "./tasks/**/*",
    "./hardhat.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

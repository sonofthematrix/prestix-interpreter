{
  "name": "@tpt/reown-appkit-module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/esm/exports/index.js",
  "types": "./dist/types/exports/index.d.ts",
  "files": [
    "dist",
    "!tsconfig.tsbuildinfo",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/exports/index.js",
      "require": "./dist/esm/exports/index.js",
      "types": "./dist/types/exports/index.d.ts"
    },
    "./config": "./src/config/index.ts",
    "./context": "./src/context/index.tsx",
    "./theme": "./src/theme/tokenizin-palace-theme.ts",
    "./components": "./src/components/index.ts",
    "./components/layouts": "./src/components/layouts/index.ts",
    "./components/navigation": "./src/components/navigation/index.ts",
    "./components/ui": "./src/components/ui/index.ts",
    "./components/common": "./src/components/common/index.ts",
    "./components/auth": "./src/components/auth/index.ts",
    "./components/brand-assets": "./src/components/brand-assets/index.ts",
    "./styles": "./src/styles/index.ts",
    "./lib": "./src/lib/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./stores": "./src/stores/index.ts",
    "./pages": "./src/app/index.ts"
  },
  "scripts": {
    "build:clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json --noEmit && mkdir -p dist && ([ -d src/types ] && cp -r src/types dist/types || true) && ([ -d src/config ] && cp -r src/config dist/config || true) && ([ -d src/components ] && cp -r src/components dist/components || true) && ([ -d src/hooks ] && cp -r src/hooks dist/hooks || true) && ([ -d src/stores ] && cp -r src/stores dist/stores || true) && ([ -d src/styles ] && cp -r src/styles dist/styles || true) && ([ -d src/utils ] && cp -r src/utils dist/utils || true)",
    "watch": "tsc --watch",
    "test": "vitest run --coverage.enabled=true -- coverage.reporter=json --coverage.reporter=json-summary --coverage.reportOnFailure=true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "peerDependencies": {
    "@reown/appkit": "^1.8.18",
    "@reown/appkit-adapter-wagmi": "^1.8.18",
    "@reown/appkit-common": "^1.8.18",
    "@reown/appkit-controllers": "^1.8.18",
    "@reown/appkit-wallet": "^1.8.18",
    "@zenstackhq/orm": "^3.3.3",
    "@walletconnect/types": "*",
    "@walletconnect/universal-provider": "*",
    "@tanstack/react-query": "^5.75.5",
    "@wagmi/core": "^3.0.0",
    "next": "^16.0.7",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "viem": "^2.40.3",
    "wagmi": "^3.0.2",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.555.0",
    "zustand": "^5.0.8",
    "tailwindcss": "^3.4.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.45.4",
    "zod": "^3.22.4",
    "date-fns": "^4.1.0",
    "sonner": "^2.0.7",
    "valtio": "2.1.7"
  },
  "devDependencies": {
    "@types/node": "22.13.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "0.25.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.7",
    "typescript": "5.8.3",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "webpack": "^5.95.0"
  },
  "dependencies": {
    "@zenstackhq/cli": "^3.3.3",
    "baseline-browser-mapping": "^2.8.32",
    "html5-qrcode": "^2.3.8",
    "qrcode.react": "^4.2.0",
    "dayjs": "^1.11.10",
    "big.js": "^6.2.1"
  },
  "optionalDependencies": {
    "hardhat": "^2.22.0"
  }
}

// Tokenizin - Consolidated ZModel Schema
// Premium marketplace for luxury goods and services with AI-powered assistance
// This schema serves as the single source of truth for the entire application
// Auto-generates: UI components, API endpoints, forms, tables, themes, and more

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma Client Generator - REQUIRED for database operations
generator client {
  provider = "prisma-client-js"
}

// ZenStack v3 Generator - REQUIRED for ZenStack functionality
generator zenstack {
  provider = "@zenstackhq/orm"
  output = "./zenstack"
}

// ZenStack v3 Beta Configuration
// The policy plugin enables access control attributes

// Optional: React hooks for frontend data fetching
// plugin hooks {
//   provider = '@zenstackhq/tanstack-query'
//   target = 'react'
//   version = 'v5'
//   output = './lib/hooks'
//   suspense = false
// }


// ENUMS


enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
  CUSTOM
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD_OUT
  DISCONTINUED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  STRIPE
  BANK_TRANSFER
  CASH_ON_DELIVERY
  CRYPTO
}

enum NotificationType {
  ORDER_PLACED
  ORDER_SHIPPED
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REVIEW_REQUEST
  PROMOTION
  SYSTEM
  ANNOUNCEMENT
  TASK
  INFO
  ROLE_REQUEST
  CONFIRMATION
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  DELETED
}

enum AIProfileType {
  ARCHITECT
  DEVELOPER
  TESTER
  DEVOPS
  WRITER
}

enum ThemeType {
  LIGHT
  DARK
  SYSTEM
  CUSTOM
  MERCHANT
}

enum ComponentType {
  FORM
  TABLE
  CARD
  NAVIGATION
  LAYOUT
  WIDGET
  AUTH
}

enum FieldType {
  TEXT
  EMAIL
  PASSWORD
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  TEXTAREA
  FILE
  IMAGE
}

enum NavigationCategory {
  MAIN
  DOCS
  ADMIN
  AUTH
  TOOLS
}

enum ValidationType {
  REQUIRED
  EMAIL
  MIN_LENGTH
  MAX_LENGTH
  PATTERN
  CUSTOM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum PropertyCategory {
  HOUSE
  APARTMENT
  COMMERCIAL
  CONDO
  VILLA
  ESTATE
  LAND
  YACHT
}

enum PropertyStatus {

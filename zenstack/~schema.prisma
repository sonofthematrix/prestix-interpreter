/// NextAuth Account — links external OAuth/wallet providers to a User
model Account {
    id String @id() @default(cuid())
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    type String
    provider String
    providerAccountId String
    refresh_token String? @db.Text()
    access_token String? @db.Text()
    expires_at Int?
    token_type String?
    scope String?
    id_token String? @db.Text()
    session_state String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()

    @@unique([provider, providerAccountId])
    @@index([userId])
    @@map("accounts")
}

/// NextAuth Session — tracks active browser sessions
model Session {
    id String @id() @default(cuid())
    sessionToken String @unique()
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    expires DateTime
    ipAddress String?
    userAgent String?
    deviceType String?
    country String?
    createdAt DateTime @default(now())

    @@index([userId])
    @@map("sessions")
}

/// Email verification token
model VerificationToken {
    id String @id() @default(cuid())
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    token String @unique()
    expires DateTime
    usedAt DateTime?
    createdAt DateTime @default(now())

    @@index([userId])
    @@map("verification_tokens")
}

/// Password reset token (forgot-password flow). Create/read/update via system or PLATFORM_ADMIN.
model PasswordResetToken {
    id String @id() @default(cuid())
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    token String @unique()
    expires DateTime
    usedAt DateTime?
    createdAt DateTime @default(now())

    @@index([userId])
    @@map("password_reset_tokens")
}

/// AppKit WalletConnect session (SIWE — Sign-In with Ethereum)
model WalletSession {
    id String @id() @default(cuid())
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    walletAddress String
    chainId Int
    network BlockchainNetwork @default(POLYGON_MAINNET)
    networkName String?
    nonce String @unique()
    message String? @db.Text()
    signature String? @db.Text()
    sessionId String? @unique()
    nonceExpiry DateTime?
    verifiedAt DateTime?
    isActive Boolean @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    expiresAt DateTime
    lastUsedAt DateTime? @default(now())
    userAgent String? @db.Text()
    ipAddress String?

    @@index([userId])
    @@index([walletAddress])
    @@map("wallet_sessions")
}

/// Historical record of wallet connections
model WalletConnection {
    id String @id() @default(cuid())
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    walletAddress String

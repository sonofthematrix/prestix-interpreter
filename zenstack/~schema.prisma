    lastExecutedAt DateTime?
    metadata Json?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()

    @@index([name])
    @@index([status])
    @@index([createdAt])
    @@map("agent_procedures")
}

/// Persistent learning memory — corrections, glossary terms, style rules, and
/// semantic embeddings. Replaces the flat JSON file `data/interpreter-learning.json`.
model LearningMemory {
    id String @id() @default(cuid())
    type String
    mode String
    term String?
    meaning String? @db.Text()
    sourceText String? @db.Text()
    wrongOutput String? @db.Text()
    correctedOutput String? @db.Text()
    rule String? @db.Text()
    payload Json?
    embedding Json?
    note String?
    userId String?
    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
    createdAt DateTime @default(now())

    @@index([type])
    @@index([mode])
    @@index([term])
    @@index([userId])
    @@index([createdAt])
    @@map("learning_memories")
}

model AuditLog {
    id String @id() @default(cuid())
    actorId String?
    actorRole String?
    action String
    targetType String
    targetId String
    changes Json?
    ipAddress String?
    userAgent String? @db.Text()
    metadata Json?
    createdAt DateTime @default(now())

    @@index([actorId])
    @@index([targetType, targetId])
    @@index([action])
    @@index([createdAt])
    @@map("audit_logs")
}
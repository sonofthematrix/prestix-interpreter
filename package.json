{
  "name": "@tokenizin/prestixapp",
  "version": "1.0.0",
  "description": "Promohub, for entertainment industry promoters service provider",
  "private": false,
  "license": "MIT",
  "author": "Tokenizin Team",
  "homepage": "https://github.com/tokenizin/presetix.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokenizin/presetix.app.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./stores": {
      "import": "./dist/stores/index.js",
      "types": "./dist/stores/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/index.css",
      "types": "./dist/styles/index.d.ts"
    }
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:vercel:slim": "NODE_OPTIONS='--max-old-space-size=16384' bash scripts/build-vercel-slim.sh",
    "build:vercel:prebuilt": "bun run build:vercel:slim && vercel build --prod --local-config vercel.prebuilt.json",
    "deploy:vercel:prebuilt": "bun run build:vercel:prebuilt && vercel deploy --prebuilt --prod",
    "deploy:vercel:local": "bun run build:vercel:slim && vercel deploy --prod --local-config vercel.prebuilt.json",
    "deploy:vercel": "bun run deploy:vercel:local",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "zen:generate": "zen generate",
    "db:push": "zen db push dev --accept-data-loss",
    "db:migrate": "prisma migrate dev --schema zenstack/prisma/schema.prisma",
    "db:studio": "prisma studio --schema zenstack/prisma/schema.prisma",
    "db:seed:missfish": "bun scripts/seed-missfish-partner-hub.ts",
    "db:seed:promoters": "bun scripts/seed-promoters-and-transactions.ts",
    "db:seed:bookings-promoters": "bun scripts/seed-bookings-with-promoters.ts",
    "organize:images:missfish": "bun scripts/organize-images-to-missfish.ts",
    "fix:images:missfish": "bun scripts/fix-missfish-image-naming.ts",
    "upload:images:missfish": "bun scripts/upload-missfish-images-to-blob.ts",
    "test": "vitest",
    "test:unit": "vitest",
    "test:promoter": "vitest src/app/api/promoter/ scripts/compute-promoter-performance",
    "test:e2e": "playwright test",
    "test:e2e:promoter": "playwright test tests/e2e/promoter-magic-link.spec.ts",
    "test:auth": "vitest",
    "setup:system-user": "bun scripts/setup-system-user-sql.ts",
    "enforce:redux": "echo 'Redux compliance: hub pages use hubListStore. Run: bun run type-check'",
    "postinstall": "([ -f scripts/run-postinstall.js ] && node scripts/run-postinstall.js) || echo 'Postinstall patches skipped'"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@reduxjs/toolkit": "^2.2.1",
    "@reown/appkit": "^1.8.18",
    "@reown/appkit-adapter-wagmi": "^1.8.18",
    "@reown/appkit-common": "^1.8.18",
    "@reown/appkit-siwe": "^1.8.18",
    "@reown/appkit-ui": "^1.8.18",
    "@reown/appkit-wallet": "^1.8.18",
    "@vercel/blob": "^2.3.0",
    "@zenstackhq/orm": "^3.4.2",
    "@zenstackhq/plugin-policy": "^3.4.2",
    "@zenstackhq/runtime": "^1.2.2",
    "@zenstackhq/tanstack-query": "^3.4.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^3.4.0",
    "framer-motion": "^11.11.17",
    "jose": "^6.1.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.462.0",
    "next": "^9.3.3",
    "next-auth": "^3.29.10",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-redux": "^9.1.0",
    "resend": "^6.1.3",
    "siwe": "^3.0.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.40.3",
    "wagmi": "^3.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.18",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@zenstackhq/cli": "^3.2.1",
    "autoprefixer": "^10.4.13",
    "dotenv": "^17.2.3",
    "postcss": "^8.4.21",
    "prisma": "^6.16.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.7"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.4.1",
    "postgres": "^3.4.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "overrides": {
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "bun@1.0.0"
}
